# RAG Complete Implementation - Environment Configuration
# Copy this file to .env and fill in your actual values

# =================
# Required Settings
# =================

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.1

# Supabase Configuration (Primary vector store)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_TABLE_NAME=documents

# Database Configuration (Alternative to Supabase)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_db
DB_USER=postgres
DB_PASSWORD=your-database-password

# =================
# Optional Settings
# =================

# Text Chunking Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHUNK_SEPARATORS="[\"\n\n\", \"\n\", \". \", \"! \", \"? \", \" \"]"

# Retrieval Configuration
RETRIEVAL_TOP_K=5
RETRIEVAL_SIMILARITY_THRESHOLD=0.7
RETRIEVAL_RERANK=true
RETRIEVAL_MAX_CHARS=4000

# Langfuse Observability (Optional but recommended)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

# Application Settings
APP_NAME="RAG Complete Implementation"
VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# =================
# Development Settings
# =================

# For development/testing purposes
PYTEST_CURRENT_TEST=true

# =================
# Docker Settings
# =================

# These are used by docker-compose.yml
# Override the database settings when using Docker
POSTGRES_DB=rag_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password123

# Redis Configuration (Optional caching)
REDIS_URL=redis://localhost:6379

# Prometheus/Grafana (Optional monitoring)
GF_SECURITY_ADMIN_PASSWORD=admin123

# =================
# Performance Tuning
# =================

# Embedding batch processing
EMBEDDING_BATCH_SIZE=100
EMBEDDING_TIMEOUT=60

# Database connection pool
DB_MIN_CONNECTIONS=1
DB_MAX_CONNECTIONS=10

# Request timeout settings
REQUEST_TIMEOUT=30
QUERY_TIMEOUT=60

# =================
# Security Settings
# =================

# Set these in production
SECRET_KEY=your-secret-key-for-sessions
ALLOWED_HOSTS=localhost,127.0.0.1

# Rate limiting (if implemented)
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# =================
# Feature Flags
# =================

# Enable/disable specific features
ENABLE_HYBRID_SEARCH=true
ENABLE_QUERY_CACHING=true
ENABLE_METRICS_EXPORT=true
ENABLE_HEALTH_CHECKS=true

# =================
# Cost Management
# =================

# Token limits for cost control
MAX_TOKENS_PER_QUERY=2000
MAX_QUERIES_PER_USER_PER_HOUR=100
DAILY_TOKEN_BUDGET=1000000

# =================
# Example Values
# =================

# For testing/development, you can use these patterns:
# OPENAI_API_KEY=sk-proj-abcd1234...
# SUPABASE_URL=https://abcdefghijklmnop.supabase.co  
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
# LANGFUSE_PUBLIC_KEY=pk-lf-abcd1234...
# LANGFUSE_SECRET_KEY=sk-lf-abcd1234...