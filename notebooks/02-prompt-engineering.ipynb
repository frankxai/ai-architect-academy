    "class AdvancedPromptingTechniques:\n",
    "    \"\"\"Collection of advanced prompting patterns\"\"\"\n",
    "    \n",
    "    @staticmethod\n",
    "    def self_consistency_prompt(question: str, num_paths: int = 3) -> List[str]:\n",
    "        \"\"\"Generate multiple reasoning paths for self-consistency\"\"\"\n",
    "        base_prompt = f\"\"\"\n",
    "Question: {question}\n",
    "\n",
    "Let me work through this step-by-step using a different approach:\n",
    "\"\"\"\n",
    "        \n",
    "        prompts = []\n",
    "        approaches = [\n",
    "            \"Let me break this down methodically:\",\n",
    "            \"I'll approach this from first principles:\",\n",
    "            \"Let me think about this problem differently:\",\n",
    "            \"Using another strategy to verify:\",\n",
    "            \"Let me cross-check with an alternative method:\"\n",
    "        ]\n",
    "        \n",
    "        for i in range(min(num_paths, len(approaches))):\n",
    "            prompt = f\"\"\"\n",
    "Question: {question}\n",
    "\n",
    "{approaches[i]}\n",
    "\"\"\".strip()\n",
    "            prompts.append(prompt)\n",
    "        \n",
    "        return prompts\n",
    "    \n",
    "    @staticmethod\n",
    "    def constitutional_ai_prompt(question: str, principles: List[str]) -> str:\n",
    "        \"\"\"Constitutional AI approach with explicit principles\"\"\"\n",
    "        principles_text = \"\\n\".join([f\"- {principle}\" for principle in principles])\n",
    "        \n",
    "        prompt = f\"\"\"\n",
    "I will answer this question following these principles:\n",
    "{principles_text}\n",
    "\n",
    "Question: {question}\n",
    "\n",
    "Let me first consider how each principle applies to this question, then provide my response:\n",
    "\n",
    "Principle Analysis:\n",
    "[I'll analyze each principle's relevance]\n",
    "\n",
    "Response:\n",
    "[My answer following the principles]\n",
    "\n",
    "Principle Verification:\n",
    "[Checking that my response aligns with the principles]\n",
    "\"\"\".strip()\n",
    "        \n",
    "        return prompt\n",
    "    \n",
    "    @staticmethod\n",
    "    def role_based_prompt(question: str, role: str, expertise_areas: List[str], \n",
    "                         context: str = \"\") -> str:\n",
    "        \"\"\"Role-based prompting with specific expertise\"\"\"\n",
    "        expertise_text = \", \".join(expertise_areas)\n",
    "        \n",
