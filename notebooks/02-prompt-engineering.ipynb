    "## 2. Few-Shot Learning Patterns\n",
    "\n",
    "Few-shot learning uses examples to guide the model's behavior for specific tasks."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class FewShotLearning:\n",
    "    \"\"\"Implementation of various few-shot learning patterns\"\"\"\n",
    "    \n",
    "    @staticmethod\n",
    "    def classification_prompt(examples: List[Dict], query: str, labels: List[str]) -> str:\n",
    "        \"\"\"Few-shot classification prompt\"\"\"\n",
    "        prompt_parts = [\"I need to classify text into the following categories: \" + \", \".join(labels)]\n",
    "        prompt_parts.append(\"\\nHere are some examples:\")\n",
    "        prompt_parts.append(\"\")\n",
    "        \n",
    "        for example in examples:\n",
    "            prompt_parts.append(f\"Text: {example['text']}\")\n",
    "            prompt_parts.append(f\"Category: {example['label']}\")\n",
    "            prompt_parts.append(\"\")\n",
    "        \n",
    "        prompt_parts.append(f\"Text: {query}\")\n",
    "        prompt_parts.append(\"Category:\")\n",
    "        \n",
    "        return \"\\n\".join(prompt_parts)\n",
    "    \n",
    "    @staticmethod\n",
    "    def extraction_prompt(examples: List[Dict], query: str, fields: List[str]) -> str:\n",
    "        \"\"\"Few-shot information extraction prompt\"\"\"\n",
    "        prompt_parts = [f\"Extract the following information from text: {', '.join(fields)}\"]\n",
    "        prompt_parts.append(\"\\nExamples:\")\n",
    "        prompt_parts.append(\"\")\n",
    "        \n",
    "        for example in examples:\n",
    "            prompt_parts.append(f\"Text: {example['text']}\")\n",
    "            prompt_parts.append(\"Extracted:\")\n",
    "            for field in fields:\n",
    "                value = example['extracted'].get(field, 'Not found')\n",
    "                prompt_parts.append(f\"- {field}: {value}\")\n",
    "            prompt_parts.append(\"\")\n",
    "        \n",
    "        prompt_parts.append(f\"Text: {query}\")\n",
    "        prompt_parts.append(\"Extracted:\")\n",
    "        \n",
    "        return \"\\n\".join(prompt_parts)\n",
    "    \n",
    "    @staticmethod\n",
    "    def format_transformation_prompt(examples: List[Dict], query: str, \n",
    "                                   source_format: str, target_format: str) -> str:\n",
    "        \"\"\"Few-shot format transformation prompt\"\"\"\n",
    "        prompt_parts = [f\"Convert from {source_format} to {target_format} format.\"]\n",
    "        prompt_parts.append(\"\\nExamples:\")\n",
    "        prompt_parts.append(\"\")\n",
    "        \n",
    "        for example in examples:\n",
    "            prompt_parts.append(f\"{source_format}: {example['input']}\")\n",
    "            prompt_parts.append(f\"{target_format}: {example['output']}\")\n",
    "            prompt_parts.append(\"\")\n",
    "        \n",
    "        prompt_parts.append(f\"{source_format}: {query}\")\n",
    "        prompt_parts.append(f\"{target_format}:\")\n",
    "        \n",
    "        return \"\\n\".join(prompt_parts)\n",
    "    \n",
    "    @staticmethod\n",
    "    def style_transfer_prompt(examples: List[Dict], query: str, target_style: str) -> str:\n",
    "        \"\"\"Few-shot style transfer prompt\"\"\"\n",
    "        prompt_parts = [f\"Rewrite the text in {target_style} style.\"]\n",
    "        prompt_parts.append(\"\\nExamples:\")\n",
    "        prompt_parts.append(\"\")\n",
    "        \n",
    "        for example in examples:\n",
    "            prompt_parts.append(f\"Original: {example['original']}\")\n",
    "            prompt_parts.append(f\"{target_style}: {example['rewritten']}\")\n",
    "            prompt_parts.append(\"\")\n",
    "        \n",
    "        prompt_parts.append(f\"Original: {query}\")\n",
    "        prompt_parts.append(f\"{target_style}:\")\n",
    "        \n",
    "        return \"\\n\".join(prompt_parts)"
   ]
  },
