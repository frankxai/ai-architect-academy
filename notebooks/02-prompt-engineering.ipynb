    "# Example 1: Zero-shot CoT\n",
    "math_question = \"A store sells apples for $2 per pound. If I buy 3.5 pounds and pay with a $10 bill, how much change do I get?\"\n",
    "\n",
    "zero_shot_prompt = ChainOfThoughtPrompting.zero_shot_cot(math_question)\n",
    "print(\"=\" * 60)\n",
    "print(\"ZERO-SHOT CHAIN-OF-THOUGHT\")\n",
    "print(\"=\" * 60)\n",
    "print(zero_shot_prompt)\n",
    "print(\"\\nLLM Response:\")\n",
    "print(\"-\" * 30)\n",
    "response = llm.generate(zero_shot_prompt)\n",
    "print(response)\n",
    "\n",
