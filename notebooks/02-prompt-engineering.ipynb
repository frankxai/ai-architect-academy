    "    \n",
    "    analysis_results.append({\n",
    "        'Quality Level': quality_level,\n",
    "        'Complexity Score': analysis['complexity_score'],\n",
    "        'Quality Grade': analysis['quality_grade'],\n",
    "        'Word Count': analysis['word_count'],\n",
    "        'Has Context': analysis['has_context'],\n",
    "        'Has Examples': analysis['has_examples'],\n",
    "        'Has Format Spec': analysis['has_format_specification']\n",
    "    })\n",
    "    \n",
    "    print(f\"\\n{quality_level.upper()} PROMPT:\")\n",
    "    print(\"-\" * 30)\n",
    "    print(f\"Prompt: {prompt[:100]}{'...' if len(prompt) > 100 else ''}\")\n",
    "    print(f\"Quality Grade: {analysis['quality_grade']}\")\n",
    "    print(f\"Complexity Score: {analysis['complexity_score']:.2f}\")\n",
    "    print(f\"Word Count: {analysis['word_count']}\")\n",
    "    \n",
    "    if suggestions:\n",
    "        print(\"Improvement Suggestions:\")\n",
    "        for suggestion in suggestions[:3]:  # Show top 3\n",
    "            print(f\"  • {suggestion}\")\n",
    "\n",
    "# Create comparison DataFrame\n",
    "comparison_df = pd.DataFrame(analysis_results)\n",
    "print(\"\\n\\n📊 COMPARISON TABLE:\")\n",
    "print(\"=\" * 60)\n",
    "print(comparison_df.to_string(index=False))\n",
    "\n",
    "# Visualize prompt quality metrics\n",
    "fig = go.Figure()\n",
    "\n",
    "fig.add_trace(go.Bar(\n",
    "    x=comparison_df['Quality Level'],\n",
    "    y=comparison_df['Complexity Score'],\n",
    "    name='Complexity Score',\n",
    "    marker_color='lightblue'\n",
    "))\n",
    "\n",
    "fig.update_layout(\n",
    "    title='Prompt Quality Comparison',\n",
    "    xaxis_title='Quality Level',\n",
    "    yaxis_title='Complexity Score',\n",
    "    yaxis=dict(range=[0, 1])\n",
    ")\n",
    "\n",
    "fig.show()\n",
    "\n",
    "# Display checklist\n",
    "checklist = PromptBestPractices.create_prompt_checklist()\n",
    "\n",
    "print(\"\\n\\n✅ PROMPT ENGINEERING CHECKLIST:\")\n",
    "print(\"=\" * 60)\n",
    "\n",
