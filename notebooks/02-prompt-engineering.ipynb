    "\"\"\".strip()\n",
    "        \n",
    "        return prompt\n",
    "    \n",
    "    @staticmethod\n",
    "    def meta_prompting(question: str) -> str:\n",
    "        \"\"\"Meta-prompting: prompting about prompting\"\"\"\n",
    "        prompt = f\"\"\"\n",
    "Question: {question}\n",
