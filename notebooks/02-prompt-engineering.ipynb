    "## 6. Prompt Engineering Best Practices\n",
    "\n",
    "Key principles for effective prompt design."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class PromptBestPractices:\n",
    "    \"\"\"Collection of prompt engineering best practices\"\"\"\n",
    "    \n",
    "    @staticmethod\n",
    "    def analyze_prompt_quality(prompt: str) -> Dict[str, Any]:\n",
    "        \"\"\"Analyze a prompt for quality indicators\"\"\"\n",
    "        analysis = {\n",
    "            'length': len(prompt),\n",
    "            'word_count': len(prompt.split()),\n",
    "            'has_clear_instruction': bool(re.search(r'(please|help|explain|analyze|describe|write|create)', prompt.lower())),\n",
    "            'has_context': bool(re.search(r'(context|background|given|assume)', prompt.lower())),\n",
    "            'has_examples': bool(re.search(r'(example|for instance|such as)', prompt.lower())),\n",
    "            'has_constraints': bool(re.search(r'(must|should|do not|avoid|limit)', prompt.lower())),\n",
    "            'has_format_specification': bool(re.search(r'(format|structure|organize|bullet|numbered)', prompt.lower())),\n",
    "            'question_count': len(re.findall(r'\\?', prompt)),\n",
    "            'imperative_count': len(re.findall(r'\\b(please|help|explain|describe|write|create)\\b', prompt.lower())),\n",
    "            'complexity_score': 0  # Will be calculated\n",
    "        }\n",
    "        \n",
    "        # Calculate complexity score\n",
    "        complexity_factors = [\n",
    "            analysis['has_clear_instruction'],\n",
    "            analysis['has_context'],\n",
    "            analysis['has_examples'],\n",
    "            analysis['has_constraints'],\n",
    "            analysis['has_format_specification'],\n",
    "            analysis['word_count'] > 50,  # Sufficient detail\n",
    "            analysis['word_count'] < 500,  # Not too verbose\n",
    "        ]\n",
    "        \n",
    "        analysis['complexity_score'] = sum(complexity_factors) / len(complexity_factors)\n",
    "        analysis['quality_grade'] = (\n",
    "            'Excellent' if analysis['complexity_score'] >= 0.8 else\n",
    "            'Good' if analysis['complexity_score'] >= 0.6 else\n",
    "            'Needs Improvement'\n",
    "        )\n",
    "        \n",
    "        return analysis\n",
    "    \n",
    "    @staticmethod\n",
    "    def improve_prompt_suggestions(prompt: str) -> List[str]:\n",
    "        \"\"\"Provide suggestions for improving a prompt\"\"\"\n",
    "        analysis = PromptBestPractices.analyze_prompt_quality(prompt)\n",
    "        suggestions = []\n",
    "        \n",
    "        if not analysis['has_clear_instruction']:\n",
    "            suggestions.append(\"Add a clear instruction verb (explain, analyze, describe, etc.)\")\n",
    "        \n",
    "        if not analysis['has_context']:\n",
    "            suggestions.append(\"Provide relevant context or background information\")\n",
    "        \n",
    "        if not analysis['has_examples']:\n",
    "            suggestions.append(\"Consider adding examples to clarify expectations\")\n",
    "        \n",
    "        if not analysis['has_constraints']:\n",
    "            suggestions.append(\"Specify constraints or requirements (length, format, etc.)\")\n",
    "        \n",
    "        if not analysis['has_format_specification']:\n",
    "            suggestions.append(\"Specify the desired output format\")\n",
    "        \n",
    "        if analysis['word_count'] < 20:\n",
    "            suggestions.append(\"Provide more detail to reduce ambiguity\")\n",
    "        \n",
    "        if analysis['word_count'] > 500:\n",
    "            suggestions.append(\"Consider reducing length for better focus\")\n",
    "        \n",
    "        if analysis['question_count'] == 0 and analysis['imperative_count'] == 0:\n",
    "            suggestions.append(\"Add a clear question or instruction\")\n",
    "        \n",
    "        return suggestions\n",
    "    \n",
    "    @staticmethod\n",
    "    def create_prompt_checklist() -> Dict[str, List[str]]:\n",
    "        \"\"\"Comprehensive prompt engineering checklist\"\"\"\n",
    "        return {\n",
    "            \"Clarity & Specificity\": [\n",
    "                \"Is the instruction clear and unambiguous?\",\n",
    "                \"Have I specified the desired output format?\",\n",
    "                \"Are the requirements well-defined?\",\n",
    "                \"Have I avoided jargon and complex language?\"\n",
    "            ],\n",
    "            \"Context & Background\": [\n",
    "                \"Have I provided sufficient context?\",\n",
    "                \"Is the background information relevant?\",\n",
    "                \"Have I defined any specialized terms?\",\n",
    "                \"Is the scope clearly bounded?\"\n",
    "            ],\n",
    "            \"Examples & Demonstrations\": [\n",
    "                \"Would examples help clarify expectations?\",\n",
    "                \"Are the examples diverse and representative?\",\n",
    "                \"Do examples show the desired format?\",\n",
    "                \"Are counterexamples needed?\"\n",
    "            ],\n",
    "            \"Constraints & Guidelines\": [\n",
    "                \"Have I specified length requirements?\",\n",
    "                \"Are there any content restrictions?\",\n",
    "                \"Have I mentioned tone/style preferences?\",\n",
    "                \"Are there accuracy requirements?\"\n",
    "            ],\n",
    "            \"Structure & Organization\": [\n",
    "                \"Is the prompt logically organized?\",\n",
    "                \"Are instructions in order of importance?\",\n",
    "                \"Is formatting consistent?\",\n",
    "                \"Are sections clearly separated?\"\n",
    "            ],\n",
    "            \"Testing & Validation\": [\n",
    "                \"Have I tested with edge cases?\",\n",
    "                \"Does it work with different inputs?\",\n",
    "                \"Is the output consistently good?\",\n",
    "                \"Have I measured performance metrics?\"\n",
    "            ]\n",
    "        }"
   ]
  },
