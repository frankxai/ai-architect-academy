    "## 4. A/B Testing Framework for Prompts\n",
    "\n",
    "Systematic prompt optimization through controlled testing."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@dataclass\n",
    "class PromptTestResult:\n",
    "    prompt_id: str\n",
    "    prompt_text: str\n",
    "    response: str\n",
    "    metrics: Dict[str, float]\n",
    "    timestamp: float\n",
    "    tokens_used: int\n",
    "\n",
    "\n",
    "class PromptABTester:\n",
    "    \"\"\"A/B testing framework for prompt optimization\"\"\"\n",
    "    \n",
    "    def __init__(self, llm_client):\n",
    "        self.llm = llm_client\n",
    "        self.test_results = []\n",
    "        self.metrics_functions = {}\n",
    "    \n",
    "    def add_metric(self, name: str, metric_func):\n",
    "        \"\"\"Add a custom metric function\"\"\"\n",
    "        self.metrics_functions[name] = metric_func\n",
    "    \n",
    "    def run_test(self, prompts: Dict[str, str], test_inputs: List[str], \n",
    "                 iterations: int = 3) -> Dict[str, List[PromptTestResult]]:\n",
    "        \"\"\"Run A/B test on multiple prompts\"\"\"\n",
    "        results = {prompt_id: [] for prompt_id in prompts.keys()}\n",
    "        \n",
    "        for iteration in range(iterations):\n",
    "            for test_input in test_inputs:\n",
    "                for prompt_id, prompt_template in prompts.items():\n",
    "                    # Format prompt with test input\n",
    "                    formatted_prompt = prompt_template.format(input=test_input)\n",
    "                    \n",
    "                    # Generate response\n",
    "                    start_time = time.time()\n",
    "                    response = self.llm.generate(formatted_prompt)\n",
    "                    end_time = time.time()\n",
    "                    \n",
    "                    # Calculate metrics\n",
    "                    metrics = {\n",
    "                        'response_time': end_time - start_time,\n",
    "                        'response_length': len(response),\n",
    "                        'word_count': len(response.split())\n",
    "                    }\n",
    "                    \n",
    "                    # Apply custom metrics\n",
    "                    for metric_name, metric_func in self.metrics_functions.items():\n",
    "                        try:\n",
    "                            metrics[metric_name] = metric_func(test_input, response)\n",
    "                        except Exception as e:\n",
    "                            metrics[metric_name] = 0.0\n",
    "                    \n",
    "                    # Store result\n",
    "                    result = PromptTestResult(\n",
    "                        prompt_id=prompt_id,\n",
    "                        prompt_text=formatted_prompt,\n",
    "                        response=response,\n",
    "                        metrics=metrics,\n",
    "                        timestamp=time.time(),\n",
    "                        tokens_used=len(formatted_prompt) // 4  # Rough estimate\n",
    "                    )\n",
    "                    \n",
    "                    results[prompt_id].append(result)\n",
    "                    self.test_results.append(result)\n",
    "        \n",
    "        return results\n",
    "    \n",
    "    def analyze_results(self, results: Dict[str, List[PromptTestResult]]) -> pd.DataFrame:\n",
    "        \"\"\"Analyze A/B test results\"\"\"\n",
    "        analysis_data = []\n",
    "        \n",
    "        for prompt_id, prompt_results in results.items():\n",
    "            if not prompt_results:\n",
    "                continue\n",
    "            \n",
    "            # Aggregate metrics\n",
    "            metrics_data = {}\n",
    "            all_metrics = prompt_results[0].metrics.keys()\n",
    "            \n",
    "            for metric in all_metrics:\n",
    "                values = [r.metrics[metric] for r in prompt_results if metric in r.metrics]\n",
    "                if values:\n",
    "                    metrics_data[f\"{metric}_mean\"] = np.mean(values)\n",
    "                    metrics_data[f\"{metric}_std\"] = np.std(values)\n",
    "                    metrics_data[f\"{metric}_min\"] = np.min(values)\n",
    "                    metrics_data[f\"{metric}_max\"] = np.max(values)\n",
    "            \n",
    "            analysis_data.append({\n",
    "                'prompt_id': prompt_id,\n",
    "                'total_tests': len(prompt_results),\n",
    "                'avg_tokens': np.mean([r.tokens_used for r in prompt_results]),\n",
    "                **metrics_data\n",
    "            })\n",
    "        \n",
    "        return pd.DataFrame(analysis_data)\n",
    "    \n",
    "    def visualize_results(self, results_df: pd.DataFrame, metric: str = 'response_length_mean'):\n",
    "        \"\"\"Visualize A/B test results\"\"\"\n",
    "        fig = go.Figure()\n",
    "        \n",
    "        fig.add_trace(go.Bar(\n",
    "            x=results_df['prompt_id'],\n",
    "            y=results_df[metric],\n",
    "            name=metric,\n",
    "            marker_color='lightblue'\n",
    "        ))\n",
    "        \n",
    "        fig.update_layout(\n",
    "            title=f'A/B Test Results: {metric}',\n",
    "            xaxis_title='Prompt Version',\n",
    "            yaxis_title=metric,\n",
    "            showlegend=False\n",
    "        )\n",
    "        \n",
    "        fig.show()\n",
    "        \n",
    "        return fig"
   ]
  },
