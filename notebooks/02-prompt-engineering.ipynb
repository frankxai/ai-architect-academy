    "        \"answer\": \"30 mph\"\n",
    "    }\n",
    "]\n",
    "\n",
    "few_shot_prompt = ChainOfThoughtPrompting.few_shot_cot(math_question, examples)\n",
    "print(\"\\n\\n=\" * 60)\n",
    "print(\"FEW-SHOT CHAIN-OF-THOUGHT\")\n",
    "print(\"=\" * 60)\n",
