    "## 3. Prompt Templates: Building Reusable Patterns"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class PromptTemplate:\n",
    "    \"\"\"Flexible prompt template system\"\"\"\n",
    "    \n",
    "    def __init__(self, template: str, required_vars: List[str], optional_vars: Dict[str, str] = None):\n",
    "        self.template = template\n",
    "        self.required_vars = required_vars\n",
    "        self.optional_vars = optional_vars or {}\n",
    "    \n",
    "    def format(self, **kwargs) -> str:\n",
    "        \"\"\"Format the template with provided variables\"\"\"\n",
    "        # Check required variables\n",
    "        missing_vars = [var for var in self.required_vars if var not in kwargs]\n",
    "        if missing_vars:\n",
    "            raise ValueError(f\"Missing required variables: {missing_vars}\")\n",
    "        \n",
    "        # Add optional variables with defaults\n",
    "        format_vars = kwargs.copy()\n",
    "        for var, default in self.optional_vars.items():\n",
    "            if var not in format_vars:\n",
    "                format_vars[var] = default\n",
    "        \n",
    "        return self.template.format(**format_vars)\n",
    "    \n",
    "    def get_token_count(self, **kwargs) -> int:\n",
    "        \"\"\"Estimate token count for the formatted prompt\"\"\"\n",
    "        formatted_prompt = self.format(**kwargs)\n",
    "        # Simple approximation: 1 token ≈ 4 characters\n",
    "        return len(formatted_prompt) // 4\n",
    "\n",
    "\n",
    "class PromptLibrary:\n",
    "    \"\"\"Collection of useful prompt templates\"\"\"\n",
    "    \n",
    "    @staticmethod\n",
    "    def get_analysis_template() -> PromptTemplate:\n",
    "        \"\"\"Template for analytical tasks\"\"\"\n",
    "        template = \"\"\"\n",
    "You are an expert analyst. Please analyze the following {content_type}:\n",
    "\n",
    "{content}\n",
    "\n",
    "Please provide your analysis focusing on:\n",
    "1. {focus_area_1}\n",
    "2. {focus_area_2}\n",
    "3. {focus_area_3}\n",
    "\n",
    "Format your response as:\n",
    "- **Key Findings**: [Your main findings]\n",
    "- **Insights**: [Your detailed insights]\n",
    "- **Recommendations**: [Your actionable recommendations]\n",
    "\n",
    "{additional_instructions}\n",
    "\"\"\".strip()\n",
    "        \n",
    "        return PromptTemplate(\n",
    "            template=template,\n",
    "            required_vars=[\"content_type\", \"content\", \"focus_area_1\", \"focus_area_2\", \"focus_area_3\"],\n",
    "            optional_vars={\"additional_instructions\": \"\"}\n",
    "        )\n",
    "    \n",
    "    @staticmethod\n",
    "    def get_creative_writing_template() -> PromptTemplate:\n",
    "        \"\"\"Template for creative writing tasks\"\"\"\n",
    "        template = \"\"\"\n",
    "Write a {content_type} about {topic}.\n",
    "\n",
    "Style: {style}\n",
    "Tone: {tone}\n",
    "Target audience: {audience}\n",
    "Length: {length}\n",
    "\n",
    "Key elements to include:\n",
    "- {element_1}\n",
    "- {element_2}\n",
    "- {element_3}\n",
    "\n",
    "{constraints}\n",
    "\n",
    "Begin writing:\n",
    "\"\"\".strip()\n",
    "        \n",
    "        return PromptTemplate(\n",
    "            template=template,\n",
    "            required_vars=[\"content_type\", \"topic\", \"element_1\", \"element_2\", \"element_3\"],\n",
    "            optional_vars={\n",
    "                \"style\": \"engaging and descriptive\",\n",
    "                \"tone\": \"professional yet approachable\",\n",
    "                \"audience\": \"general audience\",\n",
    "                \"length\": \"medium-length\",\n",
    "                \"constraints\": \"\"\n",
    "            }\n",
    "        )\n",
    "    \n",
    "    @staticmethod\n",
    "    def get_code_review_template() -> PromptTemplate:\n",
    "        \"\"\"Template for code review tasks\"\"\"\n",
    "        template = \"\"\"\n",
    "Please review the following {language} code:\n",
    "\n",
    "```{language}\n",
    "{code}\n",
    "```\n",
    "\n",
    "Focus your review on:\n",
    "1. **Code Quality**: Readability, maintainability, and best practices\n",
    "2. **Performance**: Efficiency and optimization opportunities\n",
    "3. **Security**: Potential vulnerabilities and security concerns\n",
    "4. **Testing**: Test coverage and edge cases\n",
    "{custom_focus}\n",
    "\n",
    "Please provide:\n",
    "- **Overall Assessment**: [Brief summary]\n",
    "- **Issues Found**: [List of issues with severity levels]\n",
    "- **Suggestions**: [Specific improvement recommendations]\n",
    "- **Positive Aspects**: [What's done well]\n",
    "\n",
    "{additional_context}\n",
    "\"\"\".strip()\n",
    "        \n",
    "        return PromptTemplate(\n",
