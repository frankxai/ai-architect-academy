    "Self-evaluation:\n",
    "[Assessment of my response quality and completeness]\n",
    "\"\"\".strip()\n",
    "        \n",
    "        return prompt\n",
    "    \n",
    "    @staticmethod\n",
    "    def iterative_refinement_prompt(question: str, previous_answer: str = \"\") -> str:\n",
